```gitignore
# Compiled and binary files
*.pyc
__pycache__/
*.o
*.obj
*.so
*.dll
*.exe
*.class

# Dependencies
venv/
.venv/
.env
.env.local
*.env.*

# Build artifacts
dist/
build/
target/

# Logs and temporary files
*.log
*.tmp
*.swp
*.swo

# Editor/IDE files
.vscode/
.idea/
*.pyc
__pycache__/

# Coverage reports
coverage/
htmlcov/
.coverage

# Python specific
*.pyc
__pycache__/
*.pyo
*.pyd
.Python
*.so
.PyInstaller/
```